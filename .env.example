APP_ENV=local
DATABASE_URL=sqlite+aiosqlite:///./videoedgeai_task.db
# If LLM_PROVIDER is omitted and GEMINI_API_KEY exists, the server uses Gemini by default.
# If no real key exists, it safely falls back to mock.
# LLM_PROVIDER=mock
MAX_ITERATIONS=5
LLM_TIMEOUT_SECONDS=60

# Optional Gemini provider.
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Optional free local LLM provider through Ollama.
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2:3b

# Optional GPT/OpenAI provider.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini

# Optional Claude provider.
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=...
# ANTHROPIC_MODEL=claude-sonnet-4-5
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional OpenAI-compatible provider, for example local LM Studio/vLLM
# or hosted OpenAI-compatible gateways.
# LLM_PROVIDER=openai_compatible
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# OPENAI_MODEL=local-model
# OPENAI_API_KEY=local
